{
  "name": "dot-com",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "build": {
    "appId": "com.dot-com.desktop",
    "productName": "Dot Com",
    "extraResources": [
      {
        "from": "build/icons",
        "to": "build/icons",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "MkDesignWeb",
        "repo": "dot-com"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icons/app.ico"
    },
    "nsis": {
      "installerIcon": "build/icons/installer.ico",
      "uninstallerIcon": "build/icons/installer.ico",
      "installerHeaderIcon": "build/icons/installer.ico"
    }
  },
  "files": [
    "dist-react/**/*",
    "dist-electron/**/*",
    "package.json"
  ],
  "scripts": {
    "build:electron": "tsc -p electron && tsc -p electron/tsconfig.preload.json",
    "dev": "npm run build:electron && concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "npm run build-react && npm run build-electron && tsc -p electron/tsconfig.preload.json",
    "build-react": "vite build",
    "build-electron": "tsc -p electron/tsconfig.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/lab": "^7.0.1-beta.23",
    "@mui/material": "^7.3.9",
    "@tensorflow/tfjs": "^4.0.0",
    "@vladmandic/face-api": "^1.7.15",
    "axios": "^1.13.5",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.7.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^40.1.0",
    "electron-builder": "^26.7.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "sass": "^1.97.3",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "wait-on": "^9.0.3"
  }
}